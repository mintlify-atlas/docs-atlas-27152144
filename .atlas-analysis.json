  "keyFeatures": [
    "Total anonymity - strips author name, email, timestamps, and metadata",
    "One-command setup - no accounts, tokens, or browser extensions required",
    "Git Smart HTTP protocol support for push and pull operations",
    "Battle-tested security with rate limiting and validation",
    "Anonymous pull requests via neutral @gitgost-anonymous bot",
    "Tor network integration for enhanced IP privacy",
    "Open source AGPL-3.0 license - fully auditable"
  ],
  "publicApiSurface": [
    "POST /v1/gh/:owner/:repo/git-receive-pack - Anonymous push",
    "POST /v1/gh/:owner/:repo/git-upload-pack - Anonymous fetch",
    "GET /v1/gh/:owner/:repo/info/refs - Git protocol discovery",
    "POST /v1/gh/:owner/:repo/issues/anonymous - Create anonymous issue",
    "POST /v1/gh/:owner/:repo/issues/:number/comments/anonymous - Add anonymous comment",
    "GET /api/stats - Service statistics",
    "GET /badges/:badge - Anonymous-friendly badges",
    "GET /health - Service health check",
    "POST /admin/panic - Emergency service suspension",
    "POST /admin/rollback - Close abusive PRs"
  ]
